# gateway-ask — environment. Copy to `.env`; every value is configuration, there
# is NO baked-in apex/domain anywhere in the crate or the Caddyfile.

# ── the sidecar (gateway-ask) ────────────────────────────────────────────────
# The loopback / private-network address the sidecar binds. The gateway reaches
# it here; it is NEVER public.
DREGG_GATEWAY_ASK_BIND=127.0.0.1:8799

# The deployment's hosting apex. The domain registry reads this: it is the CNAME
# challenge target base (<site>.<apex>) and the apex a launch's <slug>.<apex>
# landing is composed under. Set it to YOUR apex.
DREGG_HOSTING_APEX=example.host

# The capability issuer public key (hex) the /auth forward-auth gate verifies
# operator tokens against. UNSET ⇒ every /auth route is fail-closed (503). Mint an
# issuer with the dregg-auth tooling and put its PUBLIC key here.
# DREGG_GATEWAY_AUTH_ROOT_PUBKEY=

# ── the Caddy front (Caddyfile.on-demand-tls placeholders) ───────────────────
HOSTING_APEX=example.host
ACME_EMAIL=ops@example.host
GATEWAY_ASK_UPSTREAM=127.0.0.1:8799
SITE_UPSTREAM=127.0.0.1:8790
OPS_UPSTREAM=127.0.0.1:8090

# ── deploy.sh (cross-build + stage-then-atomic-swap) ─────────────────────────
# BOX_HOST=your-box.example
# SSH_KEY=~/.ssh/box.pem
# BOX_USER=ubuntu
# REMOTE_DIR=/opt/gateway-ask
# SERVICE=gateway-ask
# STAGE_PORT=18799
# LIVE_PORT=8799
# HEALTH_TIMEOUT=60
# BACKUPS_KEEP=5
