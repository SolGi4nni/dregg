# deploy/launchpad/.env.example — the dregg launchpad-web stack env template.
#
# Copy to hbox at ~/.config/dregg/launchpad.env and fill the real values, then
# `chmod 600 ~/.config/dregg/launchpad.env`. NEVER commit the filled file.
# Read by dregg-launchpad-web.service (the hbox node unit).
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │ LAUNCHPAD WEB (dregg-launchpad-web.service — launchpad-web/server.mjs)    │
# └──────────────────────────────────────────────────────────────────────────┘

# Bind interface for the launchpad web server — the TAILSCALE interface (hbox-dregg,
# 100.95.240.73), so the AWS gateway's Caddy reaches it over the tailnet. NEVER 0.0.0.0
# (only tailnet peers may reach it; the public internet cannot). LAUNCHPAD_HOST unset ->
# node binds ALL interfaces (local-dev / gate behaviour) — SET it here for hbox.
LAUNCHPAD_HOST=100.95.240.73
# 8785 is FREE on hbox (8790/8781/8787 already taken: games web / drex-web / dreggcloud).
PORT=8785

# The public testnet RPC the backend indexer READS the DreggLaunchpad contract over.
# Base-Sepolia or Robinhood Chain (chainId 46630). The browser also uses this RPC to
# drive the real contract with the USER's own wallet (window.ethereum). READ-only from
# the server's side — no key here. (Use a private/Alchemy endpoint in production for
# reliability; the public endpoints are fine for the testnet rehearsal.)
#   Base-Sepolia:     https://sepolia.base.org
#   Robinhood Chain:  https://rpc.testnet.chain.robinhood.com
LAUNCHPAD_RPC=https://sepolia.base.org

# The deployed DreggLaunchpad address on that testnet. EMBER fills this AFTER the
# funded-key broadcast (chain/script/DeployLaunchpad.s.sol prints "DreggLaunchpad :"
# — see deploy/launchpad/RUNBOOK.md step (c)). Unset -> the API 503s (no launches).
LAUNCHPAD_ADDRESS=

# ── OPTIONAL ────────────────────────────────────────────────────────────────
# Node-driven source: read launches as a real turn stream from a LIVE dregg node
# instead of the EVM contract (server.mjs NodeLaunchIndexer). Leave UNSET for the
# rung-1 testnet rehearsal — the on-chain contract is the whole thing and needs ZERO
# dregg. Set only if you also want the node-driven demo alongside (single-node dev).
# DREGG_NODE=http://127.0.0.1:8420

# ┌──────────────────────────────────────────────────────────────────────────┐
# │ GATEWAY / DEPLOY (read by the AWS GATEWAY's Caddy, NOT the hbox unit)     │
# └──────────────────────────────────────────────────────────────────────────┘
# These are read by deploy/launchpad/caddy/Caddyfile.launchpad, which runs ON THE
# GATEWAY (set them in the gateway Caddy's environment, e.g. its systemd Environment=).
# They are NOT used by the hbox unit.
# The public launchpad domain the gateway's Caddy serves with Let's Encrypt TLS.
DREGG_LAUNCHPAD_DOMAIN=launchpad.dregg.fg-goose.online
# The Tailscale upstream the gateway reverse-proxies to (hbox-dregg:8785).
DREGG_LAUNCHPAD_UPSTREAM=100.95.240.73:8785

# ┌──────────────────────────────────────────────────────────────────────────┐
# │ CONTRACT TESTNET DEPLOY (chain/script/DeployLaunchpad.s.sol — EMBER only) │
# └──────────────────────────────────────────────────────────────────────────┘
# The funded deployer key + broadcast are the EMBER/outward step (NOT read by any hbox
# unit; NOT placed by an agent). Kept here only to document the deploy env. The dry-run
# (deploy-launchpad.sh contract-dryrun) is KEYLESS and needs none of these.
#   export DEPLOYER_PRIVATE_KEY=0x<funded testnet key>     # EMBER input, NEVER committed
#   export BASE_SEPOLIA_RPC_URL=https://sepolia.base.org   # foundry.toml rpc alias
#   export ROBINHOOD_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com
