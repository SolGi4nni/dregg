{
  "uid": "dregg-security",
  "title": "dregg \u00b7 Security",
  "description": "Refusals, probes, and gossip abuse \u2014 the someone-is-knocking pane. Every series here is a refusal counter: flat is good.",
  "tags": [
    "dregg",
    "security"
  ],
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Auth failures (24h)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "dregg-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dregg-prometheus"
          },
          "expr": "sum(increase(dregg_auth_failures_total[24h]))",
          "refId": "A",
          "legendFormat": "auth"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      }
    },
